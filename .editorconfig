root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csproj,props,targets}]
indent_style = space
indent_size = 4

[*.{astro,css,json,js,jsx,md,mdx,mjs,ts,tsx,yaml,yml}]
indent_style = space
indent_size = 2

[*.cs]
# RS0026/RS0027 forbid public methods with paired overloads using optional parameters.
# IJobClient ships paired Task / Task<T> variants of Run/Trigger/Stream/Wait by design.
dotnet_diagnostic.RS0026.severity = none
dotnet_diagnostic.RS0027.severity = none
